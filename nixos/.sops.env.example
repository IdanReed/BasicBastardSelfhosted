# NixOS host secrets
# Copy this to .sops.env and encrypt with:
#   SOPS_AGE_KEY_FILE=../age-key.txt sops -e -i .sops.env
#
# Or create directly with:
#   SOPS_AGE_KEY_FILE=../age-key.txt sops edit .sops.env

# Tailscale auth key (get from https://login.tailscale.com/admin/settings/keys)
# Use a reusable key if you plan to re-provision frequently
TAILSCALE_AUTH_KEY=tskey-auth-xxxxx
