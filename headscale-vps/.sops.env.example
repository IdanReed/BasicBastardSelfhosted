# VPS host secrets
# Copy to .sops.env and encrypt with:
#   SOPS_AGE_KEY_FILE=../age-key.txt sops -e -i .sops.env

# Tailscale/Headscale auth key for this VPS to join its own network
# Generate from Headscale: headscale preauthkeys create --user admin --reusable
# Or from Tailscale admin console for initial bootstrap
TAILSCALE_AUTH_KEY=tskey-auth-xxxxx
