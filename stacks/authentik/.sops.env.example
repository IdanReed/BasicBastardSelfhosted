# Authentik secrets
# Copy to .sops.env and encrypt with: sops -e -i .sops.env

# PostgreSQL password
PG_PASS=changeme_generate_random_string

# Authentik secret key (generate with: openssl rand -base64 36)
AUTHENTIK_SECRET_KEY=changeme_generate_with_openssl_rand

# OIDC client secret for Headscale (generate with: openssl rand -hex 32)
HEADSCALE_OIDC_CLIENT_SECRET=changeme_generate_with_openssl_rand_hex

# Optional: SMTP for password reset emails
# SMTP_USER=
# SMTP_PASS=
