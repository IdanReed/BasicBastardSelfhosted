# Headscale secrets
# Copy to .sops.env and encrypt with: sops -e -i .sops.env

# Public URL for Headscale (must match DNS)
HEADSCALE_SERVER_URL=https://headscale.idanreed.com

# OIDC configuration (Authentik)
HEADSCALE_OIDC_ISSUER=https://headscale.idanreed.com:9443/application/o/headscale/
HEADSCALE_OIDC_CLIENT_ID=headscale
HEADSCALE_OIDC_CLIENT_SECRET=changeme_must_match_authentik_secret
